cat > .gitignore << 'EOF'
# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.so

# Build / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
.venv313/
venv/
env/
ENV/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs / runtime artifacts
*.log
logs/
tmp/
temp/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Environment / secrets
.env
.env.*
!.env.example
secrets/
*.pem
*.key

# Project-specific large/runtime assets
models/
assets/
recordings/
snapshots/
exports/

# Optional datasets
data/
datasets/
EOF